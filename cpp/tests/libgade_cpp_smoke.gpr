with "../../libgade_cpp.gpr";

project Libgade_CPP_Smoke is

   for Source_Dirs use (".");
   for Object_Dir use "../../obj/cpp/tests";
   for Library_Dir use "../../lib";
   for Library_Kind use "static";
   for Library_Name use "gade_cpp_smoke";
   for Languages use ("C++");

   package Compiler is
      for Default_Switches ("C++") use ("-std=c++17", "-I../../cpp");
   end Compiler;

end Libgade_CPP_Smoke;
